{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GET YOUR SHIT SORTED",
  "version": "0.1.0-alpha",
  "identifier": "ca.snapsmack.gyss",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "GET YOUR SHIT SORTED",
        "width": 1400,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "center": true,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "displayLanguageSelector": false
      }
    },
    "linux": {
      "deb": {},
      "appimage": {}
    }
  }
}
