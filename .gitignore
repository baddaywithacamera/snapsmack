# Claude Commander lives in its own repo
projects/claude-commander/

# Backup files and server-specific config
*.bak
.htaccess
wotcha.html
smack-central/KEY-ROTATION-INSTRUCTIONS.txt

# Temporary reference copy of pixhellated.ca live site
pixhellated_reference/

# Reference snapshots — local-only, never ship
reference/

# Claude's session-continuity notes (gitignored — for future Claude sessions)
_continuity/

# Private spec / planning documents directory
tools/_specs/

# Skin design spec documents — private planning files
skins/**/*.docx

# Claude session state and worktrees — never part of source
_claudepowertools/
.claude/worktrees/

# Chaplin skin design reference files — private, gitignored
skins/chaplin/reference work from Claude Design - gitignore/

# Instagram export reference data — private, never commit
dropagram/
tools/flkr-fckr/_pycheck.out
tools/smack-up-your-backup/_suyb_check.out

_gitlock_trash/
_gittrash2/

tools/gyss/src-tauri/target/


# Crash-recovery snapshots and quarantined files — dev scratch, never source
# (auto-dumped by SMACKBACK; corrupt files staged for deletion). Untracked so
# they stop deploying to prod and tripping the integrity scan.
_crash-recovery-*/
_to_delete/
