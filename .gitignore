# Live database credentials — never commit these
core/db.php
smack-central/sc-config.php

# Backups contain full source + database dumps — never commit
backups/

# Schema reference file IS tracked — it is the canonical source of truth for
# all table definitions and must stay in sync with install.php + migrations.
# database/schema/

# Updater temp files
/tmp/snapsmack_update/

# User uploads (too large, site-specific)
img_uploads/
media_assets/

# Claude / AI tooling
CLAUDE.md

# Spec / planning documents — not part of source
_spec/

# OS junk
.DS_Store
Thumbs.db
desktop.ini
HIP-TO-BE-SQUARE-SPEC.docx
PICASA-WEB-ALBUMS-SPEC.docx


# Release packages (built by Smack Central, not stored in source)
releases/

# Build artifacts from skin packaging / registry generation
packages/
registry.json

# Server-side auth file (cPanel / host-generated, not source code)
auth.php

# PyInstaller build artifacts (Smack Your Batch Up)
tools/ft-batch-poster/build/
tools/ft-batch-poster/dist/
tools/ft-batch-poster/*.spec

# ExifTool legacy (replaced by piexif)
tools/ft-batch-poster/exiftool.exe
tools/ft-batch-poster/exiftool_files/

# Plugin builds (not part of SnapSmack core)
sofobomo-canada.zip
