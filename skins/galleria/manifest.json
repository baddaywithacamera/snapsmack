        "htbs_footer_link_hover": {
            "section": "FOOTER",
            "type": "color",
            "label": "Footer Link Hover",
            "default": "#a0803f",
            "selector": ".htbs-footer a:hover, footer a:hover",
            "property": "color"
        },
