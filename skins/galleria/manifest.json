            "selector": ":root",
            "property": "--archive-frames"
        },
        "htbs_show_filmstrip": {
            "section": "SINGLE IMAGE",
            "type": "select",
            "label": "Show Filmstrip",
            "default": "1",
            "options": {
                "1": "Yes",
                "0": "No"
            },
            "selector": ":root",
            "property": "--show-filmstrip"
        },
        "htbs_plaque_style": {
            "section": "SINGLE IMAGE",
            "type": "select",
            "label": "Plaque Style",
