            "section": "LAYOUT",
            "type": "range",
            "label": "Content Max Width (px)",
            "default": "1200",
            "min": "800",
            "max": "1800",
            "selector": ":root",
            "property": "--content-max-width",
            "unit": "px"
        },
        "htbs_header_height": {
            "section": "LAYOUT",
            "type": "range",
            "label": "Header Height (px)",
            "default": "60",
            "min": "40",
            "max": "100",
            "selector": ":root",
            "property": "--header-height",
            "unit": "px"
