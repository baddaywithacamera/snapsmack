                "minimal": "Minimal",
                "classic": "Classic",
                "hidden": "Hidden"
            },
            "selector": ":root",
            "property": "--plaque-style"
        },
        "htbs_force_square": {
            "section": "IMAGE CROP",
            "type": "select",
            "label": "Force Square Crop",
            "default": "0",
            "options": [
                "No (Original Aspect)",
                "Yes (Square)"
