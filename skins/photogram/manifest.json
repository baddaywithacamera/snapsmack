                },
                "land43": {
                    "label": "Landscape (4:3)",
                    "css": "{ --pg-tile-aspect: 4 / 3; }"
                },
                "land32": {
                    "label": "Landscape (3:2)",
                    "css": "{ --pg-tile-aspect: 3 / 2; }"
                },
                "wide169": {
                    "label": "Wide (16:9)",
                    "css": "{ --pg-tile-aspect: 16 / 9; }"
                },
                "polaroid": {
                    "label": "Polaroid print (823:1000)",
                    "css": "{ --pg-tile-aspect: 823 / 1000; }"
                },
                "go": {
                    "label": "Polaroid Go (47:60)",
                    "css": "{ --pg-tile-aspect: 47 / 60; }"
                },
                "instax_mini": {
                    "label": "Instax Mini (62:46)",
                    "css": "{ --pg-tile-aspect: 62 / 46; }"
                },
                "instax_wide": {
                    "label": "Instax Wide (99:62)",
                    "css": "{ --pg-tile-aspect: 99 / 62; }"
                }
            },
            "selector": ":root",
            "property": "custom-pg-tile-aspect"
        },
        "pg_tile_border_width": {
            "section": "GRID",
            "type": "select",
            "label": "Tile Border",
            "default": "none",
            "options": {
                "none": {
                    "label": "None",
                    "css": "{ --pg-tile-border-width: 0px; }"
                },
                "thin": {
                    "label": "1px",
                    "css": "{ --pg-tile-border-width: 1px; }"
                },
                "thick": {
                    "label": "2px",
                    "css": "{ --pg-tile-border-width: 2px; }"
                }
            },
            "selector": ":root",
            "property": "custom-pg-tile-border-width"
        },
        "pg_tile_border_color": {
            "section": "GRID",
            "type": "color",
            "label": "Tile Border Colour",
            "default": "#000000",
            "selector": ":root",
            "property": "--pg-tile-border-color"
        },
        "pg_avatar_shape": {
            "section": "PROFILE",
            "type": "select",
            "label": "Avatar Shape",
            "default": "circle",
            "options": {
                "circle": {
                    "label": "Circle",
                    "css": "{ --pg-avatar-radius: 50%; }"
                },
                "rounded": {
                    "label": "Rounded Square",
                    "css": "{ --pg-avatar-radius: 12px; }"
                }
            },
            "selector": ":root",
            "property": "custom-pg-avatar-shape"
        },
        "pg_accent_color": {
            "section": "COLOURS",
            "type": "color",
            "label": "Accent Colour",
            "default": "#3D6B9E",
            "selector": ":root",
            "property": "--pg-accent"
        },
        "pg_bg_color": {
            "section": "COLOURS",
            "type": "color",
            "label": "Column Background",
            "default": "#FFFFFF",
            "selector": ":root",
            "property": "--pg-bg"
        },
        "pg_outer_bg_color": {
            "section": "COLOURS",
            "type": "color",
            "label": "Page Background",
            "default": "#EFEFEF",
            "selector": ":root",
            "property": "--pg-outer-bg"
        },
        "pg_sheet_speed": {
            "section": "COMMENTS",
            "type": "select",
            "label": "Sheet Animation Speed",
            "default": "normal",
            "options": {
                "fast": {
                    "label": "Fast (200ms)",
                    "css": "{ --pg-sheet-speed: 200ms; }"
                },
                "normal": {
                    "label": "Normal (280ms)",
                    "css": "{ --pg-sheet-speed: 280ms; }"
                },
                "slow": {
                    "label": "Slow (400ms)",
                    "css": "{ --pg-sheet-speed: 400ms; }"
                }
            },
            "selector": ":root",
            "property": "custom-pg-sheet-speed"
        },
        "pg_show_discover": {
            "section": "NAVIGATION",
            "type": "select",
            "label": "Show Discover Tab",
            "default": "1",
            "options": {
                "1": "Yes",
                "0": "No"
            }
        },
