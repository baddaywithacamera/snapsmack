{
    "schema_version": 1,
    "name": "PHOTOGRAM",
    "version": "2.0.14",
    "author": "Sean McCormick",
    "support": "sean@baddaywithacamera.ca",
    "description": "A shadow of what a photo-sharing app used to be. Phone-native layout: 3-column archive grid, full-aspect post view, inline likes, bottom-sheet comments. Reproduces the Pixelfed / classic Instagram experience in a self-hosted blog.",
    "status": "stable",
    "features": {
        "supports_wall": false,
        "masonry_supported": false,
        "archive_layouts": [
            "square"
        ],
        "supports_slider": false,
        "has_landing": true,
        "post_modes": [
            "image"
        ],
        "instagram_mode": true,
        "carousel": true,
        "community": [
            "likes",
            "comments"
        ],
        "mobile_only": true,
        "archive_filter": false
    },
    "require_scripts": [
        "smack-community",
        "smack-photogram",
        "smack-photogram-feed",
        "smack-image-fade-load",
        "smack-slider"
    ],
    "options": {
        "pg_column_width": {
            "section": "LAYOUT",
            "type": "select",
            "label": "Desktop Width",
            "default": "phone",
            "options": {
                "phone": {
                    "label": "Phone Column (480px)",
                    "css": "{ --pg-column-width: 480px; }"
                },
                "wide": {
                    "label": "Wide (900px)",
                    "css": "{ --pg-column-width: 900px; }"
                },
                "fullwidth": {
                    "label": "Full Width",
                    "css": "{ --pg-column-width: 100%; }"
                }
            },
            "selector": ":root",
            "property": "custom-pg-column-width"
        },
        "pg_grid_gutter": {
            "section": "LAYOUT",
            "type": "select",
            "label": "Side Gutter",
            "default": "none",
            "options": {
                "none": {
                    "label": "None (edge to edge)",
                    "css": "{ --pg-grid-gutter: 0px; }"
                },
                "small": {
                    "label": "Small (16px)",
                    "css": "{ --pg-grid-gutter: 16px; }"
                },
                "medium": {
                    "label": "Medium (32px)",
                    "css": "{ --pg-grid-gutter: 32px; }"
                },
                "large": {
                    "label": "Large (64px)",
                    "css": "{ --pg-grid-gutter: 64px; }"
                }
            },
            "selector": ":root",
            "property": "custom-pg-grid-gutter"
        },
        "pg_grid_gap": {
            "section": "GRID",
            "type": "select",
            "label": "Tile Spacing",
            "default": "none",
            "options": {
                "none": {
                    "label": "None",
                    "css": "{ --pg-grid-gap: 0px; }"
                },
                "hairline": {
                    "label": "1px",
                    "css": "{ --pg-grid-gap: 1px; }"
                },
                "small": {
                    "label": "2px",
                    "css": "{ --pg-grid-gap: 2px; }"
                },
                "medium": {
                    "label": "4px",
                    "css": "{ --pg-grid-gap: 4px; }"
                },
                "large": {
                    "label": "8px",
                    "css": "{ --pg-grid-gap: 8px; }"
                }
            },
            "selector": ":root",
            "property": "custom-pg-grid-gap"
        },
        "pg_tile_aspect": {
            "section": "GRID",
            "type": "select",
            "label": "Tile Aspect Ratio",
            "default": "square",
            "options": {
                "square": {
                    "label": "Square (1:1)",
                    "css": "{ --pg-tile-aspect: 1 / 1; }"
                },
                "portrait45": {
                    "label": "Portrait (4:5)",
                    "css": "{ --pg-tile-aspect: 4 / 5; }"
                },
                "portrait34": {
                    "label": "Portrait (3:4)",
                    "css": "{ --pg-tile-aspect: 3 / 4; }"
                },
                "portrait23": {
                    "label": "Portrait (2:3)",
